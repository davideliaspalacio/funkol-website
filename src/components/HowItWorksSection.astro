---
const steps = [
  {
    number: "01",
    title: "crea tu perfil",
    description: "Regístrate, sube tu foto y define tus servicios. En 2 minutos estás listo.",
    icon: "🎤",
    gradient: "linear-gradient(135deg, #7c4dff, #536dfe)",
    image: "/personInPc.png",
  },
  {
    number: "02",
    title: "pon tu precio",
    description: "Tú decides cuánto cobrar por mensajes, videollamadas y preguntas exclusivas.",
    icon: "💰",
    gradient: "linear-gradient(135deg, #00e5ff, #00bcd4)",
    image: "/aceptOrDecline.png",
  },
  {
    number: "03",
    title: "cobra al instante",
    description: "Cada interacción se cobra automáticamente. Retira tu dinero cuando quieras.",
    icon: "🚀",
    gradient: "linear-gradient(135deg, #e040fb, #ea80fc)",
    image: "/cohete.png",
  },
];
---

<section class="how-it-works">
  <!-- NGL-style subtle gradient line -->
  <div class="section-line" aria-hidden="true"></div>

  <div class="hiw-inner">
    <div class="hiw-header">
      <span class="hiw-eyebrow" data-reveal="pop" data-delay="0">cómo funciona</span>
      <h2 class="hiw-heading" data-reveal data-delay="0.08">
        3 pasos para<br /><span class="hiw-accent">monetizar</span>
      </h2>
    </div>

    <div class="hiw-cards">
      {steps.map((step, i) => (
        <div
          class="hiw-card"
          data-reveal="scale"
          data-delay={String(0.1 + i * 0.12)}
        >
          <div class="hiw-card-number" style={`background: ${step.gradient};`}>
            {step.number}
          </div>

          <div class="hiw-card-visual">
            <img src={step.image} alt="" class="hiw-card-img" />
            <div class="hiw-card-glow" style={`background: ${step.gradient};`}></div>
          </div>

          <h3 class="hiw-card-title">{step.title}</h3>
          <p class="hiw-card-desc">{step.description}</p>
        </div>
      ))}
    </div>

    <!-- Connecting line between cards (desktop) -->
    <div class="hiw-connector" aria-hidden="true">
      <div class="connector-line"></div>
    </div>
  </div>
</section>

<style>
  .how-it-works {
    background: var(--black);
    position: relative;
    z-index: 3;
    padding: 7rem 2rem 8rem;
    overflow: hidden;
  }

  /* Top gradient line separator — NGL style */
  .section-line {
    position: absolute;
    top: 0;
    left: 10%;
    right: 10%;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(224, 64, 251, 0.4), rgba(0, 229, 255, 0.4), transparent);
  }

  .hiw-inner {
    max-width: 1100px;
    margin: 0 auto;
    position: relative;
  }

  .hiw-header {
    text-align: center;
    margin-bottom: 4rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .hiw-eyebrow {
    font-family: var(--font);
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: rgba(255, 255, 255, 0.4);
    background: rgba(255, 255, 255, 0.06);
    padding: 0.5rem 1.25rem;
    border-radius: 100px;
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

  .hiw-heading {
    font-family: var(--font-display);
    font-size: clamp(2.8rem, 7vw, 5.5rem);
    font-weight: 800;
    line-height: 0.92;
    letter-spacing: -0.03em;
    text-transform: lowercase;
    color: var(--white);
  }

  .hiw-accent {
    background: linear-gradient(135deg, #00e5ff, #e040fb);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* Cards */
  .hiw-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    position: relative;
    z-index: 2;
  }

  .hiw-card {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.07);
    border-radius: 24px;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1.25rem;
    transition:
      transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1),
      border-color 0.3s ease,
      background 0.3s ease;
    cursor: default;
    position: relative;
    overflow: hidden;
  }

  .hiw-card:hover {
    transform: translateY(-8px);
    border-color: rgba(255, 255, 255, 0.14);
    background: rgba(255, 255, 255, 0.06);
  }

  .hiw-card-number {
    width: 40px;
    height: 40px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 0.85rem;
    color: #fff;
    flex-shrink: 0;
  }

  .hiw-card-visual {
    position: relative;
    width: clamp(100px, 14vw, 140px);
    height: clamp(100px, 14vw, 140px);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hiw-card-img {
    width: 100%;
    height: auto;
    object-fit: contain;
    position: relative;
    z-index: 2;
    filter: drop-shadow(0 8px 24px rgba(0, 0, 0, 0.4));
    transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .hiw-card:hover .hiw-card-img {
    transform: scale(1.1) translateY(-4px);
  }

  .hiw-card-glow {
    position: absolute;
    inset: 10%;
    border-radius: 50%;
    filter: blur(30px);
    opacity: 0.2;
    transition: opacity 0.3s ease;
  }

  .hiw-card:hover .hiw-card-glow {
    opacity: 0.35;
  }

  .hiw-card-title {
    font-family: var(--font-display);
    font-size: clamp(1.3rem, 2.2vw, 1.6rem);
    font-weight: 800;
    color: var(--white);
    text-transform: lowercase;
    letter-spacing: -0.01em;
  }

  .hiw-card-desc {
    font-family: var(--font);
    font-size: clamp(0.85rem, 1.1vw, 0.95rem);
    color: rgba(255, 255, 255, 0.5);
    line-height: 1.5;
    font-weight: 400;
  }

  /* Connector line (desktop) */
  .hiw-connector {
    position: absolute;
    top: 50%;
    left: 15%;
    right: 15%;
    z-index: 1;
    pointer-events: none;
  }

  .connector-line {
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.1), transparent);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .how-it-works {
      padding: 5rem 1.5rem;
    }

    .hiw-cards {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .hiw-card {
      padding: 1.5rem;
    }

    .hiw-connector {
      display: none;
    }

    .hiw-header {
      margin-bottom: 3rem;
    }
  }
</style>
