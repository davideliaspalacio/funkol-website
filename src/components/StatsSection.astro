---
const stats = [
  { value: "500k+", label: "mensajes pagados", accent: "linear-gradient(135deg, #00e5ff, #00bcd4)" },
  { value: "$2M+",  label: "cobrado por creadores", accent: "linear-gradient(135deg, #e040fb, #7c4dff)" },
  { value: "10k+",  label: "creadores activos", accent: "linear-gradient(135deg, #ff6d00, #ff9100)" },
  { value: "98%",   label: "tasa de cobro exitoso", accent: "linear-gradient(135deg, #00e676, #69f0ae)" },
];
---

<section class="stats">
  <!-- Gradient glow orbs — NGL style -->
  <div class="glow glow-1" aria-hidden="true"></div>
  <div class="glow glow-2" aria-hidden="true"></div>

  <div class="stats-inner">
    <h2 class="stats-heading" data-reveal data-delay="0">
      los números<br /><span class="stats-gradient">hablan solos</span>
    </h2>

    <div class="stats-grid">
      {stats.map((s, i) => (
        <div
          class="stat-card"
          data-reveal="scale"
          data-delay={String(i * 0.1)}
        >
          <div class="stat-accent" style={`background: ${s.accent};`}></div>
          <span class="stat-value">{s.value}</span>
          <span class="stat-label">{s.label}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .stats {
    background: var(--black);
    position: relative;
    z-index: 3;
    padding: 8rem 2rem;
    overflow: hidden;
  }

  /* NGL-style gradient glow orbs */
  .glow {
    position: absolute;
    border-radius: 50%;
    filter: blur(120px);
    opacity: 0.18;
    pointer-events: none;
  }

  .glow-1 {
    width: 600px;
    height: 600px;
    background: #e040fb;
    top: -15%;
    left: -10%;
    animation: glow-drift 8s ease-in-out infinite alternate;
  }

  .glow-2 {
    width: 500px;
    height: 500px;
    background: #00e5ff;
    bottom: -15%;
    right: -10%;
    animation: glow-drift 10s ease-in-out infinite alternate-reverse;
  }

  @keyframes glow-drift {
    0%   { transform: translate(0, 0); }
    100% { transform: translate(40px, -30px); }
  }

  .stats-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4rem;
    position: relative;
    z-index: 2;
  }

  .stats-heading {
    font-family: var(--font-display);
    font-size: clamp(3rem, 8vw, 6.5rem);
    font-weight: 800;
    line-height: 0.92;
    letter-spacing: -0.03em;
    text-transform: lowercase;
    color: var(--white);
    text-align: center;
  }

  .stats-gradient {
    background: linear-gradient(135deg, #00e5ff, #e040fb);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* Card grid */
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    width: 100%;
  }

  .stat-card {
    position: relative;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 20px;
    padding: 2rem 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    text-align: center;
    overflow: hidden;
    transition:
      transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1),
      border-color 0.3s ease,
      background 0.3s ease;
    cursor: default;
  }

  .stat-card:hover {
    transform: translateY(-6px) scale(1.03);
    border-color: rgba(255, 255, 255, 0.15);
    background: rgba(255, 255, 255, 0.07);
  }

  /* Gradient accent line at top */
  .stat-accent {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    border-radius: 20px 20px 0 0;
  }

  .stat-value {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 4vw, 3.2rem);
    font-weight: 800;
    color: var(--white);
    line-height: 1;
    letter-spacing: -0.02em;
  }

  .stat-label {
    font-family: var(--font);
    font-size: clamp(0.8rem, 1.2vw, 0.95rem);
    color: rgba(255, 255, 255, 0.5);
    font-weight: 500;
    line-height: 1.3;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .stats-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .stats {
      padding: 5rem 1.5rem;
    }

    .stats-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
    }

    .stat-card {
      padding: 1.5rem 1rem;
    }
  }
</style>
