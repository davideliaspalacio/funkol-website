---
const cards = [
  {
    handle: "@ana.creator",
    type: "Mensaje directo",
    price: "$5",
    emoji: "💬",
    rotation: -6,
    delay: "0",
  },
  {
    handle: "@carlos.pro",
    type: "Videollamada 15min",
    price: "$25",
    emoji: "📹",
    rotation: 0,
    delay: "0.15",
  },
  {
    handle: "@marta.live",
    type: "Q&A exclusivo",
    price: "$3",
    emoji: "⭐",
    rotation: 7,
    delay: "0.3",
  },
];
---

<section class="showcase section-curve">
  <span class="emoji se1">🚀</span>
  <span class="emoji se2">👏</span>

  <div class="showcase-inner">
    <div class="cards-grid">
      {
        cards.map((card) => (
          <div
            class="app-card"
            style={`--card-rot: ${card.rotation}deg`}
            data-reveal="scale"
            data-delay={card.delay}
          >
            <div class="card-header">
              <div class="avatar">{card.emoji}</div>
              <div class="card-info">
                <span class="handle">{card.handle}</span>
                <span class="type">{card.type}</span>
              </div>
            </div>
            <div class="card-price">
              <span class="price-label">precio</span>
              <span class="price-value">{card.price}</span>
            </div>
            <button class="card-btn">Pagar ahora</button>
          </div>
        ))
      }
    </div>

    <h2
      class="heading-giant showcase-heading"
      data-reveal
      data-delay="0.1"
    >
      llena tu<br />wallet
    </h2>
  </div>
</section>

<style>
  .showcase {
    background: var(--gradient);
    position: relative;
    z-index: 3;
    padding: 6rem 2rem 7rem;
    overflow: hidden;
  }

  .showcase-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4rem;
  }

  /* Cards grid */
  .cards-grid {
    display: flex;
    gap: 1.5rem;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
  }

  .app-card {
    background: rgba(255, 255, 255, 0.97);
    color: var(--black);
    border-radius: 20px;
    padding: 1.5rem;
    width: clamp(220px, 25vw, 280px);
    box-shadow:
      0 20px 60px rgba(0, 0, 0, 0.18),
      0 0 0 1px rgba(0, 0, 0, 0.04);
    /* When revealed, apply tilt + subtle float */
    transition:
      transform 0.4s var(--ease-spring),
      box-shadow 0.4s ease,
      opacity 0.7s var(--ease-out);
    cursor: pointer;
  }

  /* After scroll reveal makes it visible, apply the rotation + float */
  .app-card.is-visible {
    animation: card-float 5s ease-in-out infinite;
    animation-delay: var(--float-delay, 0s);
  }

  @keyframes card-float {
    0%,
    100% {
      transform: rotate(var(--card-rot, 0deg)) translateY(0px);
    }
    50% {
      transform: rotate(var(--card-rot, 0deg)) translateY(-10px);
    }
  }

  .app-card:hover {
    transform: rotate(0deg) scale(1.05) translateY(-6px) !important;
    box-shadow:
      0 32px 80px rgba(0, 0, 0, 0.25),
      0 0 0 2px rgba(255, 255, 255, 0.5);
    animation-play-state: paused;
  }

  .card-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.25rem;
  }

  .avatar {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: var(--gradient);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.2rem;
    flex-shrink: 0;
    transition: transform 0.3s var(--ease-spring);
  }

  .app-card:hover .avatar {
    transform: scale(1.12) rotate(-8deg);
  }

  .card-info {
    display: flex;
    flex-direction: column;
  }

  .handle {
    font-weight: 700;
    font-size: 0.95rem;
    color: var(--black);
  }

  .type {
    font-size: 0.8rem;
    color: #666;
    margin-top: 2px;
  }

  .card-price {
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: #f5f5f5;
    border-radius: 12px;
    padding: 0.75rem 1rem;
    margin-bottom: 1rem;
    transition: background 0.2s ease;
  }

  .app-card:hover .card-price {
    background: #efefef;
  }

  .price-label {
    font-size: 0.8rem;
    color: #888;
    font-weight: 500;
  }

  .price-value {
    font-size: 1.4rem;
    font-weight: 700;
    background: var(--gradient-h);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .card-btn {
    width: 100%;
    padding: 0.7rem;
    border: none;
    border-radius: 100px;
    background: var(--gradient-h);
    color: var(--white);
    font-family: var(--font);
    font-weight: 700;
    font-size: 0.9rem;
    cursor: pointer;
    transition:
      opacity 0.2s ease,
      transform 0.25s var(--ease-spring),
      box-shadow 0.25s ease;
  }

  .card-btn:hover {
    opacity: 0.9;
    transform: scale(1.03);
    box-shadow: 0 4px 16px rgba(0, 154, 255, 0.4);
  }

  .card-btn:active {
    transform: scale(0.97);
  }

  /* Heading */
  .showcase-heading {
    color: var(--white);
    text-align: center;
    text-shadow: 0 4px 40px rgba(0, 0, 0, 0.12);
  }

  /* Emojis */
  .emoji {
    position: absolute;
    font-size: 3rem;
    pointer-events: none;
    animation: float 4s ease-in-out infinite;
  }

  .se1 {
    top: 10%;
    right: 5%;
    animation-duration: 4.5s;
  }
  .se2 {
    bottom: 15%;
    left: 4%;
    animation-duration: 3.8s;
    animation-delay: 0.6s;
  }

  @media (max-width: 768px) {
    .app-card.is-visible {
      animation: none;
    }
    .app-card:hover {
      transform: scale(1.03) !important;
    }
  }
</style>
