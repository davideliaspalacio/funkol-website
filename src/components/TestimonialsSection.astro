---
const testimonials = [
  {
    name: "Valentina R.",
    handle: "@vale.creates",
    photo: "https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=200&h=200&fit=crop&crop=face",
    text: "En mi primer mes cobré más de $800 solo por mensajes. Funkol cambió todo.",
    earned: "$3.2k",
    gradient: "linear-gradient(135deg, #e040fb, #7c4dff)",
  },
  {
    name: "Diego M.",
    handle: "@diego.fit",
    photo: "https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=200&h=200&fit=crop&crop=face",
    text: "Mis fans pagan por videollamadas de coaching. Es el ingreso extra que necesitaba.",
    earned: "$5.1k",
    gradient: "linear-gradient(135deg, #00e5ff, #536dfe)",
  },
  {
    name: "Camila S.",
    handle: "@cami.music",
    photo: "https://images.unsplash.com/photo-1529626455594-4ff0802cfb7e?w=200&h=200&fit=crop&crop=face",
    text: "Yo pongo el precio, ellos deciden si pagan. Así de simple. Así de justo.",
    earned: "$1.8k",
    gradient: "linear-gradient(135deg, #ff6d00, #ff9100)",
  },
];
---

<section class="testimonials">
  <div class="glow tm-glow-1" aria-hidden="true"></div>
  <div class="glow tm-glow-2" aria-hidden="true"></div>

  <div class="tm-inner">
    <div class="tm-header">
      <span class="tm-eyebrow" data-reveal="pop" data-delay="0">creadores reales</span>
      <h2 class="tm-heading" data-reveal data-delay="0.08">
        ellos ya<br /><span class="tm-accent">cobran</span>
      </h2>
    </div>

    <div class="tm-grid">
      {testimonials.map((t, i) => (
        <div
          class="tm-card"
          data-reveal="scale"
          data-delay={String(0.12 + i * 0.1)}
        >
          <!-- Earned badge -->
          <div class="tm-earned" style={`background: ${t.gradient};`}>
            <span class="tm-earned-value">{t.earned}</span>
            <span class="tm-earned-label">cobrado</span>
          </div>

          <!-- Quote -->
          <p class="tm-quote">"{t.text}"</p>

          <!-- Author -->
          <div class="tm-author">
            <div class="tm-avatar-wrap">
              <img src={t.photo} alt={t.name} class="tm-avatar" />
              <div class="tm-avatar-ring" style={`background: ${t.gradient};`}></div>
            </div>
            <div class="tm-author-info">
              <span class="tm-name">{t.name}</span>
              <span class="tm-handle">{t.handle}</span>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .testimonials {
    background: var(--black);
    position: relative;
    z-index: 3;
    padding: 7rem 2rem 8rem;
    overflow: hidden;
  }

  /* Glow orbs */
  .glow {
    position: absolute;
    border-radius: 50%;
    filter: blur(120px);
    opacity: 0.12;
    pointer-events: none;
  }

  .tm-glow-1 {
    width: 500px;
    height: 500px;
    background: #7c4dff;
    top: 10%;
    right: -8%;
    animation: tm-drift 9s ease-in-out infinite alternate;
  }

  .tm-glow-2 {
    width: 400px;
    height: 400px;
    background: #00e5ff;
    bottom: 5%;
    left: -5%;
    animation: tm-drift 11s ease-in-out infinite alternate-reverse;
  }

  @keyframes tm-drift {
    0%   { transform: translate(0, 0); }
    100% { transform: translate(30px, -25px); }
  }

  .tm-inner {
    max-width: 1100px;
    margin: 0 auto;
    position: relative;
    z-index: 2;
  }

  /* Header */
  .tm-header {
    text-align: center;
    margin-bottom: 4rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .tm-eyebrow {
    font-family: var(--font);
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: rgba(255, 255, 255, 0.4);
    background: rgba(255, 255, 255, 0.06);
    padding: 0.5rem 1.25rem;
    border-radius: 100px;
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

  .tm-heading {
    font-family: var(--font-display);
    font-size: clamp(2.8rem, 7vw, 5.5rem);
    font-weight: 800;
    line-height: 0.92;
    letter-spacing: -0.03em;
    text-transform: lowercase;
    color: var(--white);
  }

  .tm-accent {
    background: linear-gradient(135deg, #e040fb, #00e5ff);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* Cards grid */
  .tm-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .tm-card {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.07);
    border-radius: 24px;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    transition:
      transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1),
      border-color 0.3s ease,
      background 0.3s ease;
    cursor: default;
  }

  .tm-card:hover {
    transform: translateY(-6px);
    border-color: rgba(255, 255, 255, 0.14);
    background: rgba(255, 255, 255, 0.06);
  }

  /* Earned badge */
  .tm-earned {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 1rem;
    border-radius: 12px;
    align-self: flex-start;
  }

  .tm-earned-value {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.3rem;
    color: #fff;
    letter-spacing: -0.02em;
  }

  .tm-earned-label {
    font-family: var(--font);
    font-size: 0.75rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.7);
  }

  /* Quote */
  .tm-quote {
    font-family: var(--font);
    font-size: clamp(0.95rem, 1.3vw, 1.1rem);
    color: rgba(255, 255, 255, 0.75);
    line-height: 1.55;
    font-weight: 400;
    font-style: italic;
    flex: 1;
  }

  /* Author */
  .tm-author {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding-top: 1rem;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .tm-avatar-wrap {
    position: relative;
    width: 44px;
    height: 44px;
    flex-shrink: 0;
  }

  .tm-avatar {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    object-fit: cover;
    position: relative;
    z-index: 2;
  }

  .tm-avatar-ring {
    position: absolute;
    inset: -3px;
    border-radius: 50%;
    z-index: 1;
    opacity: 0.6;
    transition: opacity 0.3s ease;
  }

  .tm-card:hover .tm-avatar-ring {
    opacity: 1;
  }

  .tm-author-info {
    display: flex;
    flex-direction: column;
  }

  .tm-name {
    font-weight: 700;
    font-size: 0.9rem;
    color: var(--white);
  }

  .tm-handle {
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.4);
    font-weight: 400;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .testimonials {
      padding: 5rem 1.5rem;
    }

    .tm-grid {
      grid-template-columns: 1fr;
      gap: 1.25rem;
    }

    .tm-header {
      margin-bottom: 3rem;
    }
  }
</style>
