---
const creatorPhoto = "https://images.unsplash.com/photo-1524504388940-b1c1722653e1?w=500&h=700&fit=crop&crop=face";

const bubbles = [
  { text: "¿qué inspira tu contenido?", pos: "top-left",    delay: "0"    },
  { text: "¡eres increíble!",           pos: "top-right",   delay: "0.15" },
  { text: "¿cuándo la próxima llamada?",pos: "bottom-left", delay: "0.3"  },
  { text: "¡me encanta tu trabajo!",    pos: "bottom-right",delay: "0.45" },
];
---

<section class="community section-curve">
  <span class="emoji ce1">👀</span>
  <span class="emoji ce2">⚡</span>

  {bubbles.map((b) => (
    <div class={`bubble bubble-${b.pos}`} data-reveal="pop" data-delay={b.delay}>
      {b.text}
    </div>
  ))}

  <div class="community-inner">
    <div class="col col-left" data-reveal="slide-left" data-delay="0">
      <span class="big-word">cobra a</span>
      <span class="big-word gradient-text">tu</span>
    </div>

    <div class="col col-center" data-reveal="scale" data-delay="0.1">
      <div class="creator-photo-wrap">
        <img src={creatorPhoto} alt="Creador Funkol" class="creator-photo" />
        <!--
          data-base-transform keeps translateX(-50%) during the pop animation.
          The JS in Layout reads this and combines: translateX(-50%) scale(0.5) → translateX(-50%)
        -->
        <div
          class="creator-badge"
          data-reveal="pop"
          data-delay="0.5"
          data-base-transform="translateX(-50%)"
        >
          💗 +1k fans
        </div>
      </div>
    </div>

    <div class="col col-right" data-reveal="slide-right" data-delay="0">
      <span class="big-word">comuni-</span>
      <span class="big-word gradient-text">dad</span>
    </div>
  </div>
</section>

<style>
  .community {
    background: var(--black);
    position: relative;
    z-index: 4;
    padding: 6rem 2rem 7rem;
    overflow: hidden;
  }

  .community-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 2rem;
    position: relative;
    z-index: 2;
  }

  .col {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .col-left  { text-align: right; }
  .col-right { text-align: left; }

  .big-word {
    display: block;
    font-size: clamp(3rem, 8vw, 7rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 0.95;
    text-transform: lowercase;
    color: var(--white);
  }

  .gradient-text {
    background: var(--gradient-h);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* Creator photo */
  .creator-photo-wrap {
    position: relative;
    display: inline-block;
    transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .creator-photo-wrap:hover {
    transform: scale(1.03) translateY(-4px);
  }

  .creator-photo {
    width: clamp(200px, 25vw, 320px);
    aspect-ratio: 3/4;
    object-fit: cover;
    border-radius: 24px;
    display: block;
    box-shadow:
      0 20px 60px rgba(0, 0, 0, 0.5),
      0 0 0 1px rgba(255, 255, 255, 0.06);
    transition: box-shadow 0.4s ease;
  }

  .creator-photo-wrap:hover .creator-photo {
    box-shadow: 0 32px 80px rgba(0, 0, 0, 0.6);
  }

  .creator-badge {
    position: absolute;
    bottom: -16px;
    left: 50%;
    /* base transform = translateX(-50%) — kept by data-base-transform */
    transform: translateX(-50%);
    background: var(--white);
    color: var(--black);
    padding: 0.5rem 1.25rem;
    border-radius: 100px;
    font-weight: 700;
    font-size: 0.9rem;
    white-space: nowrap;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.2);
    transition:
      transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1),
      opacity 0.5s cubic-bezier(0.22, 1, 0.36, 1);
  }

  /* Speech bubbles — NGL style */
  .bubble {
    position: absolute;
    background: var(--white);
    color: var(--black);
    padding: 1.4rem 2rem;
    border-radius: 28px;
    font-size: clamp(1.25rem, 2.2vw, 1.6rem);
    font-weight: 800;
    font-family: var(--font-display);
    line-height: 1.25;
    text-align: center;
    max-width: 300px;
    white-space: normal;
    z-index: 3;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.45);
    transition:
      transform 0.45s cubic-bezier(0.34, 1.56, 0.64, 1),
      box-shadow 0.45s ease;
  }

  .bubble.is-visible {
    animation: float-slow 4.5s ease-in-out infinite;
  }

  /* Cada bubble salta hacia el centro con su propia dirección */
  .bubble-top-left:hover {
    transform: translate(48px, 36px) rotate(-4deg) scale(1.08);
    box-shadow: 0 20px 56px rgba(0, 0, 0, 0.55);
    animation-play-state: paused;
  }

  .bubble-top-right:hover {
    transform: translate(-48px, 36px) rotate(4deg) scale(1.08);
    box-shadow: 0 20px 56px rgba(0, 0, 0, 0.55);
    animation-play-state: paused;
  }

  .bubble-bottom-left:hover {
    transform: translate(48px, -36px) rotate(4deg) scale(1.08);
    box-shadow: 0 20px 56px rgba(0, 0, 0, 0.55);
    animation-play-state: paused;
  }

  .bubble-bottom-right:hover {
    transform: translate(-48px, -36px) rotate(-4deg) scale(1.08);
    box-shadow: 0 20px 56px rgba(0, 0, 0, 0.55);
    animation-play-state: paused;
  }

  .bubble::after {
    content: "";
    position: absolute;
    bottom: -18px;
    left: 24px;
    width: 0;
    height: 0;
    border-left: 10px solid transparent;
    border-right: 6px solid transparent;
    border-top: 20px solid var(--white);
    filter: drop-shadow(0 4px 4px rgba(0, 0, 0, 0.12));
  }

  .bubble-top-left    { top: 10%;    left: 12%;  }
  .bubble-top-right   { top: 10%;    right: 12%; }
  .bubble-bottom-left { bottom: 14%; left: 14%;  }
  .bubble-bottom-right{ bottom: 14%; right: 14%; }

  /* Floating emojis */
  .emoji {
    position: absolute;
    font-size: 2.5rem;
    pointer-events: none;
    animation: float 4s ease-in-out infinite;
    z-index: 1;
  }
  .ce1 { top: 30%;    left: 1%;  animation-duration: 4.5s; }
  .ce2 { bottom: 30%; right: 1%; animation-duration: 3.5s; animation-delay: 0.8s; }

  @media (max-width: 768px) {
    .community-inner {
      grid-template-columns: 1fr;
      text-align: center;
    }
    .col-left, .col-right { text-align: center; }
    .col-center { display: flex; justify-content: center; }
    .bubble { display: none; }
    .big-word { font-size: clamp(2.5rem, 12vw, 5rem); }
  }
</style>
