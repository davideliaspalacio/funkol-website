<section class="cta-final">
  <!-- Animated gradient bg -->
  <div class="cta-bg" aria-hidden="true"></div>

  <!-- Floating 3D objects -->
  <img src="/cohete.png"        class="cta-deco cta-d1" width="130" height="130" aria-hidden="true" alt="" />
  <img src="/emojis.png"        class="cta-deco cta-d2" width="110" height="110" aria-hidden="true" alt="" />
  <img src="/manoApuntando.png" class="cta-deco cta-d3" width="120" height="120" aria-hidden="true" alt="" />
  <img src="/world.png"         class="cta-deco cta-d4" width="100" height="100" aria-hidden="true" alt="" />

  <div class="cta-inner">
    <h2 class="cta-heading" data-reveal data-delay="0">
      empieza a<br />cobrar <span class="cta-accent">hoy</span>
    </h2>

    <p class="cta-sub" data-reveal data-delay="0.12">
      Descarga gratis. Crea tu perfil. Pon tu precio.<br />Tu comunidad ya está esperando.
    </p>

    <div class="cta-buttons" data-reveal="pop" data-delay="0.24">
      <a href="#" class="cta-btn-primary">
        <span class="cta-btn-icon">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
        </span>
        <span class="cta-btn-text">
          <span class="cta-btn-sub">descarga gratis</span>
          <span class="cta-btn-main">App Store</span>
        </span>
      </a>

      <a href="#" class="cta-btn-primary">
        <span class="cta-btn-icon">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M3.18 23.76c.3.17.64.22.99.14l12.12-6.99-2.61-2.61-10.5 9.46zM.54 1.96C.2 2.3 0 2.87 0 3.61v16.78c0 .74.2 1.31.55 1.65l.09.08 9.4-9.4v-.22L.63 1.88l-.09.08zM20.46 10.37l-2.6-1.5-2.93 2.93 2.93 2.93 2.61-1.51c.75-.43.75-1.12 0-1.55l-.01-.3zM3.18.24L15.3 7.23l-2.61 2.61L2.17.38C2.47.2 2.87.19 3.18.24z"/></svg>
        </span>
        <span class="cta-btn-text">
          <span class="cta-btn-sub">descarga gratis</span>
          <span class="cta-btn-main">Google Play</span>
        </span>
      </a>
    </div>
  </div>
</section>

<style>
  .cta-final {
    position: relative;
    z-index: 4;
    padding: 10rem 2rem;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 80vh;
  }

  /* Animated gradient background */
  .cta-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 30% 20%, rgba(124, 77, 255, 0.25) 0%, transparent 60%),
      radial-gradient(ellipse at 70% 80%, rgba(0, 229, 255, 0.2) 0%, transparent 60%),
      radial-gradient(ellipse at 50% 50%, rgba(224, 64, 251, 0.15) 0%, transparent 50%),
      var(--black);
    animation: cta-bg-shift 12s ease-in-out infinite alternate;
  }

  @keyframes cta-bg-shift {
    0%   { background-position: 0% 0%, 100% 100%, 50% 50%; }
    50%  { background-position: 20% 30%, 80% 70%, 60% 40%; }
    100% { background-position: 40% 10%, 60% 90%, 50% 60%; }
  }

  /* Floating 3D objects */
  .cta-deco {
    position: absolute;
    pointer-events: none;
    height: auto;
    filter: drop-shadow(0 8px 24px rgba(0, 0, 0, 0.4));
    z-index: 1;
    animation: float 4s ease-in-out infinite;
    opacity: 0.6;
  }

  .cta-d1 {
    width: clamp(80px, 10vw, 130px);
    top: 10%;
    left: 8%;
    --rot: -12deg;
    animation-duration: 4.2s;
  }

  .cta-d2 {
    width: clamp(70px, 9vw, 110px);
    top: 12%;
    right: 10%;
    --rot: 8deg;
    animation-duration: 5s;
    animation-delay: 0.5s;
  }

  .cta-d3 {
    width: clamp(80px, 10vw, 120px);
    bottom: 12%;
    left: 12%;
    --rot: 10deg;
    animation-duration: 4.5s;
    animation-delay: 1s;
  }

  .cta-d4 {
    width: clamp(65px, 8vw, 100px);
    bottom: 14%;
    right: 8%;
    --rot: -6deg;
    animation-duration: 3.8s;
    animation-delay: 0.3s;
  }

  /* Content */
  .cta-inner {
    position: relative;
    z-index: 2;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
    max-width: 700px;
  }

  .cta-heading {
    font-family: var(--font-display);
    font-size: clamp(3.5rem, 10vw, 8rem);
    font-weight: 800;
    line-height: 0.9;
    letter-spacing: -0.03em;
    text-transform: lowercase;
    color: var(--white);
  }

  .cta-accent {
    background: linear-gradient(135deg, #00e5ff, #e040fb);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .cta-sub {
    font-family: var(--font);
    font-size: clamp(1rem, 1.5vw, 1.15rem);
    color: rgba(255, 255, 255, 0.55);
    line-height: 1.6;
    font-weight: 400;
    max-width: 480px;
  }

  /* Buttons */
  .cta-buttons {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 1rem;
  }

  .cta-btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    background: rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.12);
    color: var(--white);
    text-decoration: none;
    padding: 1rem 2rem;
    border-radius: 16px;
    transition:
      background 0.3s ease,
      transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1),
      border-color 0.3s ease,
      box-shadow 0.3s ease;
  }

  .cta-btn-primary:hover {
    background: rgba(255, 255, 255, 0.14);
    border-color: rgba(255, 255, 255, 0.25);
    transform: scale(1.05) translateY(-3px);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.25);
  }

  .cta-btn-primary:active {
    transform: scale(0.97);
  }

  .cta-btn-icon {
    display: flex;
    align-items: center;
    opacity: 0.85;
  }

  .cta-btn-text {
    display: flex;
    flex-direction: column;
    text-align: left;
    line-height: 1.2;
  }

  .cta-btn-sub {
    font-size: 0.7rem;
    font-weight: 500;
    opacity: 0.6;
    text-transform: lowercase;
  }

  .cta-btn-main {
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 800;
    letter-spacing: -0.02em;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .cta-final {
      padding: 6rem 1.5rem;
      min-height: 70vh;
    }

    .cta-deco {
      display: none;
    }

    .cta-buttons {
      flex-direction: column;
      width: 100%;
      max-width: 280px;
    }

    .cta-btn-primary {
      justify-content: center;
      width: 100%;
    }
  }
</style>
