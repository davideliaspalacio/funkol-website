---
---

<section class="hero">

  <!-- Deco elements (reduced from 4 to 2) -->
  <img src="/cohete.png"        class="deco deco-cohete" width="110" height="110" aria-hidden="true" alt="" />
  <img src="/emojis.png"        class="deco deco-emojis" width="130" height="130" aria-hidden="true" alt="" />

  <!-- Two-column grid -->
  <div class="hero-grid">

    <!-- Left column: text + CTA -->
    <div class="hero-text">
      <h1 class="hero-heading">
        <span class="line line-1">cobra lo</span>
        <span class="line line-2">que vales.</span>
      </h1>
      <p class="subtitle">Tu tiempo tiene precio. Tus fans lo saben.</p>
      <a href="#download" class="cta-btn">
        <span class="cta-text">Descarga la app</span>
      </a>
    </div>

    <!-- Right column: app screenshots -->
    <div class="hero-visuals">
      <div class="phone phone-1" aria-hidden="true">
        <img src="/microphonechat.png" alt="" />
      </div>
      <div class="phone phone-2" aria-hidden="true">
        <img src="/aceptOrDecline.png" alt="" />
      </div>
    </div>

  </div>

  <div class="scroll-hint">scroll para mas</div>

  <!-- Ghost skeleton overlay -->
  <div class="hero-skeleton" id="heroSkeleton" aria-hidden="true">
    <div class="sk-grid">
      <div class="sk-content">
        <div class="sk-line sk-line-1"></div>
        <div class="sk-line sk-line-2"></div>
        <div class="sk-subtitle"></div>
        <div class="sk-btn"></div>
      </div>
      <div class="sk-visuals">
        <div class="sk-phone sk-phone-1"></div>
        <div class="sk-phone sk-phone-2"></div>
      </div>
    </div>
  </div>
</section>

<style>
  /* ── Keyframes ── */
  @keyframes line-up {
    from { opacity: 0; transform: translateY(60px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes fade-up {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes deco-pop {
    0%   { opacity: 0; transform: scale(0.2) rotate(var(--rot, 0deg)); }
    65%  { opacity: 1; transform: scale(1.12) rotate(var(--rot, 0deg)); }
    100% { opacity: 1; transform: scale(1) rotate(var(--rot, 0deg)); }
  }
  @keyframes cta-enter {
    from { opacity: 0; transform: scale(0.82) translateY(16px); }
    to   { opacity: 1; transform: scale(1) translateY(0); }
  }
  @keyframes phone-enter {
    from { opacity: 0; transform: translateY(40px) rotate(var(--rot, 0deg)) scale(0.9); }
    to   { opacity: 1; transform: translateY(0) rotate(var(--rot, 0deg)) scale(1); }
  }

  /* ── Section ── */
  .hero {
    background: var(--gradient);
    min-height: 100svh;
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    padding: 6rem 2rem 4rem;
  }

  /* ── Two-column grid ── */
  .hero-grid {
    position: relative;
    z-index: 4;
    width: 100%;
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: 3rem;
  }

  /* ── Left column: text ── */
  .hero-text {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .hero-heading {
    font-family: var(--font-display);
    font-size: clamp(2.8rem, 8vw, 5.5rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 0.88;
    text-transform: lowercase;
    color: var(--white);
    text-shadow: 0 4px 48px rgba(0, 0, 0, 0.12);
    display: flex;
    flex-direction: column;
  }

  .line {
    display: block;
    animation-name: line-up;
    animation-duration: 0.8s;
    animation-timing-function: cubic-bezier(0.22, 1, 0.36, 1);
    animation-fill-mode: both;
  }
  .line-1 { animation-delay: 0.05s; }
  .line-2 { animation-delay: 0.22s; }

  .subtitle {
    font-size: clamp(1rem, 2.2vw, 1.25rem);
    color: rgba(255, 255, 255, 0.88);
    margin-top: 1.25rem;
    font-weight: 500;
    animation-name: fade-up;
    animation-duration: 0.7s;
    animation-timing-function: cubic-bezier(0.22, 1, 0.36, 1);
    animation-delay: 0.4s;
    animation-fill-mode: both;
  }

  /* ── CTA button ── */
  .cta-btn {
    display: inline-block;
    margin-top: 2rem;
    padding: 0.95rem 2.75rem;
    border-radius: 100px;
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    text-decoration: none;
    cursor: pointer;
    position: relative;
    overflow: hidden;
    background: var(--cream);
    color: var(--secondary);
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.15);
    animation-name: cta-enter;
    animation-duration: 0.65s;
    animation-timing-function: cubic-bezier(0.34, 1.56, 0.64, 1);
    animation-delay: 0.58s;
    animation-fill-mode: both;
    transition:
      background 0.3s ease,
      color 0.3s ease,
      transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1),
      box-shadow 0.3s ease;
  }

  .cta-btn::before {
    content: "";
    position: absolute;
    inset: 0;
    background: var(--black);
    border-radius: inherit;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .cta-btn:hover {
    background: var(--secondary);
    color: var(--white);
    transform: scale(1.06) translateY(-3px);
    box-shadow:
      0 16px 48px rgba(0, 0, 0, 0.22),
      0 0 0 3px rgba(255, 255, 255, 0.35);
  }

  .cta-btn:active {
    transform: scale(0.97);
  }

  .cta-text {
    position: relative;
    z-index: 1;
  }

  /* ── Right column: app screenshots ── */
  .hero-visuals {
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    min-height: 300px;
  }

  .phone {
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
    animation-name: phone-enter;
    animation-duration: 0.9s;
    animation-timing-function: cubic-bezier(0.22, 1, 0.36, 1);
    animation-fill-mode: both;
  }

  .phone img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }

  .phone-1 {
    width: clamp(140px, 18vw, 220px);
    --rot: -6deg;
    transform: rotate(-6deg);
    animation-delay: 0.15s;
    z-index: 2;
    position: relative;
  }

  .phone-2 {
    width: clamp(140px, 18vw, 220px);
    --rot: 5deg;
    transform: rotate(5deg);
    animation-delay: 0.3s;
    z-index: 1;
    margin-left: -30px;
    position: relative;
  }

  /* ── Deco (reduced to 2) ── */
  .deco {
    position: absolute;
    pointer-events: none;
    height: auto;
    filter: drop-shadow(0 8px 20px rgba(0, 0, 0, 0.2));
    z-index: 3;
    animation-name: deco-pop, float;
    animation-timing-function: cubic-bezier(0.34, 1.56, 0.64, 1), ease-in-out;
    animation-iteration-count: 1, infinite;
    animation-fill-mode: both, none;
  }

  .deco-cohete {
    width: clamp(60px, 7vw, 90px);
    top: 8%;
    right: 8%;
    --rot: 20deg;
    animation-duration: 0.55s, 4.2s;
    animation-delay: 0.9s, 1.45s;
  }

  .deco-emojis {
    width: clamp(70px, 8vw, 100px);
    bottom: 10%;
    left: 5%;
    --rot: 10deg;
    animation-duration: 0.55s, 4.5s;
    animation-delay: 0.85s, 1.4s;
  }

  /* ── Scroll hint ── */
  .scroll-hint {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    color: rgba(255, 255, 255, 0.6);
    font-size: 0.82rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    animation-name: fade-up, float-slow;
    animation-duration: 0.7s, 3s;
    animation-timing-function: cubic-bezier(0.22, 1, 0.36, 1), ease-in-out;
    animation-delay: 1s, 1.7s;
    animation-fill-mode: both, none;
    animation-iteration-count: 1, infinite;
    z-index: 4;
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .hero {
      padding: 5rem 1.5rem 4rem;
    }

    .hero-grid {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 2.5rem;
    }

    .hero-text {
      align-items: center;
    }

    .hero-visuals {
      justify-content: center;
      min-height: auto;
    }

    .phone-1,
    .phone-2 {
      width: clamp(120px, 35vw, 160px);
    }

    .deco-cohete {
      width: 55px;
      top: 4%;
      right: 4%;
    }

    .deco-emojis {
      width: 60px;
      bottom: 6%;
      left: 3%;
    }
  }

  /* ── Ghost skeleton ── */
  @keyframes shimmer {
    0%   { background-position: -600px 0; }
    100% { background-position:  600px 0; }
  }

  .hero-skeleton {
    position: absolute;
    inset: 0;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--gradient);
    transition: opacity 0.5s ease;
    pointer-events: none;
  }

  .hero-skeleton.sk-hidden {
    opacity: 0;
    pointer-events: none;
  }

  .sk-grid {
    width: 100%;
    max-width: 1100px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: 3rem;
    padding: 0 2rem;
  }

  .sk-content {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .sk-visuals {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
  }

  .sk-line,
  .sk-subtitle,
  .sk-btn,
  .sk-phone {
    background: linear-gradient(
      90deg,
      rgba(255,255,255,0.12) 0%,
      rgba(255,255,255,0.28) 40%,
      rgba(255,255,255,0.12) 80%
    );
    background-size: 600px 100%;
    animation-name: shimmer;
    animation-duration: 1.4s;
    animation-timing-function: linear;
    animation-iteration-count: infinite;
    border-radius: 16px;
  }

  .sk-line {
    height: clamp(2.2rem, 7vw, 4.4rem);
    border-radius: 12px;
  }
  .sk-line-1 { width: 70%; animation-delay: 0s; }
  .sk-line-2 { width: 85%; animation-delay: 0.15s; }
  .sk-subtitle { width: 60%; height: 1.2rem; animation-delay: 0.3s; }
  .sk-btn { width: 180px; height: 3rem; border-radius: 100px; animation-delay: 0.45s; }

  .sk-phone {
    width: clamp(120px, 16vw, 180px);
    aspect-ratio: 3/4;
    border-radius: 20px;
  }
  .sk-phone-1 { transform: rotate(-6deg); animation-delay: 0.2s; }
  .sk-phone-2 { transform: rotate(5deg); margin-left: -20px; animation-delay: 0.35s; }

  @media (max-width: 768px) {
    .sk-grid {
      grid-template-columns: 1fr;
    }
    .sk-content { align-items: center; }
    .sk-line-1 { width: 60%; }
    .sk-line-2 { width: 75%; }
  }
</style>

<script>
  // ── Ghost skeleton: fade out after page load ──
  const skeleton = document.getElementById("heroSkeleton");
  if (skeleton) {
    const hide = () => {
      skeleton.classList.add("sk-hidden");
      skeleton.addEventListener("transitionend", () => skeleton.remove(), { once: true });
    };
    if (document.readyState === "complete") {
      hide();
    } else {
      window.addEventListener("load", hide);
    }
  }
</script>
