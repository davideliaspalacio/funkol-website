---
const creator1 = "https://images.unsplash.com/photo-1529626455594-4ff0802cfb7e?w=500&h=700&fit=crop&crop=face";
const creator2 = "https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=500&h=700&fit=crop&crop=face";
---

<section class="hero">

  <!-- Fotos flanqueando el texto — estilo NGL -->
  <div class="photo-card card-left" aria-hidden="true">
    <img src={creator1} alt="" />
  </div>
  <div class="photo-card card-right" aria-hidden="true">
    <img src={creator2} alt="" />
  </div>

  <!-- Objetos 3D llenando espacios — mano arriba izq, cohete arriba der,
       world abajo izq, emojis abajo der -->
  <img src="/manoApuntando.png" class="deco deco-mano"   width="120" height="120" aria-hidden="true" alt="" />
  <img src="/cohete.png"        class="deco deco-cohete" width="110" height="110" aria-hidden="true" alt="" />
  <img src="/world.png"         class="deco deco-world"  width="100" height="100" aria-hidden="true" alt="" />
  <img src="/emojis.png"        class="deco deco-emojis" width="130" height="130" aria-hidden="true" alt="" />

  <!-- Contenido central -->
  <div class="hero-content">
    <h1 class="hero-heading">
      <span class="line line-1">cobra lo</span>
      <span class="line line-2">que vales.</span>
    </h1>
    <p class="subtitle">Tu tiempo tiene precio. Tus fans lo saben.</p>
    <a href="#download" class="cta-btn">
      <span class="cta-text">¡Descarga la app!</span>
    </a>
  </div>

  <div class="scroll-hint">↓ scroll para más</div>

  <!-- Ghost skeleton overlay — shown until page loads -->
  <div class="hero-skeleton" id="heroSkeleton" aria-hidden="true">
    <div class="sk-card sk-card-left"></div>
    <div class="sk-card sk-card-right"></div>
    <div class="sk-content">
      <div class="sk-line sk-line-1"></div>
      <div class="sk-line sk-line-2"></div>
      <div class="sk-subtitle"></div>
      <div class="sk-btn"></div>
    </div>
  </div>
</section>

<style>
  /* ── Keyframes ── */
  @keyframes line-up {
    from { opacity: 0; transform: translateY(60px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes fade-up {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes card-enter-left {
    from { opacity: 0; transform: translateY(-50%) rotate(-6deg) translateX(-100px) scale(0.85); }
    to   { opacity: 1; transform: translateY(-50%) rotate(-6deg) translateX(0) scale(1); }
  }
  @keyframes card-enter-right {
    from { opacity: 0; transform: translateY(-50%) rotate(5deg) translateX(100px) scale(0.85); }
    to   { opacity: 1; transform: translateY(-50%) rotate(5deg) translateX(0) scale(1); }
  }
  @keyframes deco-pop {
    0%   { opacity: 0; transform: scale(0.2) rotate(var(--rot, 0deg)); }
    65%  { opacity: 1; transform: scale(1.12) rotate(var(--rot, 0deg)); }
    100% { opacity: 1; transform: scale(1) rotate(var(--rot, 0deg)); }
  }
  @keyframes cta-enter {
    from { opacity: 0; transform: scale(0.82) translateY(16px); }
    to   { opacity: 1; transform: scale(1) translateY(0); }
  }

  /* ── Section ── */
  .hero {
    background: var(--gradient);
    min-height: 100svh;
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    padding: 7rem 2rem 6rem;
  }

  /* ── Fotos — grandes, flanqueando, estilo NGL ── */
  .photo-card {
    position: absolute;
    width: clamp(200px, 24vw, 310px);
    aspect-ratio: 3/4;
    border-radius: 28px;
    overflow: hidden;
    top: 50%;
    box-shadow: 0 24px 72px rgba(0, 0, 0, 0.35);
    transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.4s ease;
    cursor: pointer;
    z-index: 2;
  }

  .photo-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .photo-card:hover img { transform: scale(1.06); }

  .card-left {
    left: 3%;
    animation-name: card-enter-left;
    animation-duration: 0.9s;
    animation-timing-function: cubic-bezier(0.22, 1, 0.36, 1);
    animation-delay: 0.1s;
    animation-fill-mode: both;
  }
  .card-left:hover {
    transform: translateY(-53%) rotate(-3deg) scale(1.04);
    box-shadow: 0 36px 90px rgba(0, 0, 0, 0.4);
  }

  .card-right {
    right: 3%;
    animation-name: card-enter-right;
    animation-duration: 0.9s;
    animation-timing-function: cubic-bezier(0.22, 1, 0.36, 1);
    animation-delay: 0.2s;
    animation-fill-mode: both;
  }
  .card-right:hover {
    transform: translateY(-53%) rotate(2deg) scale(1.04);
    box-shadow: 0 36px 90px rgba(0, 0, 0, 0.4);
  }

  /* ── Objetos 3D — llenan los espacios vacíos ── */
  .deco {
    position: absolute;
    pointer-events: none;
    height: auto;
    filter: drop-shadow(0 8px 20px rgba(0, 0, 0, 0.2));
    z-index: 3;
    animation-name: deco-pop, float;
    animation-timing-function: cubic-bezier(0.34, 1.56, 0.64, 1), ease-in-out;
    animation-iteration-count: 1, infinite;
    animation-fill-mode: both, none;
  }

  /* Mano — arriba izquierda (encima de la foto izq) */
  .deco-mano {
    width: clamp(85px, 10vw, 120px);
    top: 8%;
    left: 20%;
    --rot: -15deg;
    animation-duration: 0.55s, 3.8s;
    animation-delay: 0.75s, 1.3s;
  }

  /* Cohete — arriba derecha */
  .deco-cohete {
    width: clamp(80px, 9vw, 115px);
    top: 6%;
    right: 22%;
    --rot: 20deg;
    animation-duration: 0.55s, 4.2s;
    animation-delay: 0.9s, 1.45s;
  }

  /* World — abajo izquierda */
  .deco-world {
    width: clamp(80px, 9vw, 110px);
    bottom: 10%;
    left: 22%;
    --rot: -8deg;
    animation-duration: 0.55s, 5s;
    animation-delay: 1.05s, 1.6s;
  }

  /* Emojis — abajo derecha */
  .deco-emojis {
    width: clamp(90px, 11vw, 140px);
    bottom: 8%;
    right: 20%;
    --rot: 10deg;
    animation-duration: 0.55s, 4.5s;
    animation-delay: 0.85s, 1.4s;
  }

  /* ── Contenido central ── */
  .hero-content {
    position: relative;
    z-index: 4;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .hero-heading {
    font-family: var(--font-display);
    font-size: clamp(4.5rem, 14vw, 11rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 0.88;
    text-transform: lowercase;
    color: var(--white);
    text-shadow: 0 4px 48px rgba(0, 0, 0, 0.12);
    display: flex;
    flex-direction: column;
  }

  .line {
    display: block;
    animation-name: line-up;
    animation-duration: 0.8s;
    animation-timing-function: cubic-bezier(0.22, 1, 0.36, 1);
    animation-fill-mode: both;
  }
  .line-1 { animation-delay: 0.05s; }
  .line-2 { animation-delay: 0.22s; }

  .subtitle {
    font-size: clamp(1rem, 2.2vw, 1.25rem);
    color: rgba(255, 255, 255, 0.88);
    margin-top: 1.25rem;
    font-weight: 500;
    animation-name: fade-up;
    animation-duration: 0.7s;
    animation-timing-function: cubic-bezier(0.22, 1, 0.36, 1);
    animation-delay: 0.4s;
    animation-fill-mode: both;
  }

  /* ── CTA button — invierte colores en hover ── */
  .cta-btn {
    display: inline-block;
    margin-top: 2rem;
    padding: 0.95rem 2.75rem;
    border-radius: 100px;
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    text-decoration: none;
    cursor: pointer;
    position: relative;
    overflow: hidden;
    /* Estado base: crema con texto naranja */
    background: var(--cream);
    color: var(--orange);
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.15);
    animation-name: cta-enter;
    animation-duration: 0.65s;
    animation-timing-function: cubic-bezier(0.34, 1.56, 0.64, 1);
    animation-delay: 0.58s;
    animation-fill-mode: both;
    /* Transición suave de fondo y color */
    transition:
      background 0.3s ease,
      color 0.3s ease,
      transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1),
      box-shadow 0.3s ease;
  }

  /* Capa de gradiente que se revela en hover */
  .cta-btn::before {
    content: "";
    position: absolute;
    inset: 0;
    background: var(--black);
    border-radius: inherit;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .cta-btn:hover {
    background: var(--orange);
    color: var(--white);
    transform: scale(1.06) translateY(-3px);
    box-shadow:
      0 16px 48px rgba(0, 0, 0, 0.22),
      0 0 0 3px rgba(255, 255, 255, 0.35);
  }

  .cta-btn:active {
    transform: scale(0.97);
  }

  .cta-text {
    position: relative;
    z-index: 1;
  }

  /* ── Scroll hint ── */
  .scroll-hint {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    color: rgba(255, 255, 255, 0.6);
    font-size: 0.82rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    animation-name: fade-up, float-slow;
    animation-duration: 0.7s, 3s;
    animation-timing-function: cubic-bezier(0.22, 1, 0.36, 1), ease-in-out;
    animation-delay: 1s, 1.7s;
    animation-fill-mode: both, none;
    animation-iteration-count: 1, infinite;
    z-index: 4;
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .photo-card { width: clamp(140px, 28vw, 200px); }
    .card-left  { left: 1%; }
    .card-right { right: 1%; }
    .deco-mano   { left: 16%; width: 75px; }
    .deco-cohete { right: 16%; width: 72px; }
    .deco-world  { left: 14%; width: 68px; }
    .deco-emojis { right: 14%; width: 80px; }
  }

  @media (max-width: 600px) {
    .photo-card { display: none; }
    .deco { display: none; }
  }

  /* ── Ghost skeleton ── */
  @keyframes shimmer {
    0%   { background-position: -600px 0; }
    100% { background-position:  600px 0; }
  }

  .hero-skeleton {
    position: absolute;
    inset: 0;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--gradient);
    transition: opacity 0.5s ease;
    pointer-events: none;
  }

  .hero-skeleton.sk-hidden {
    opacity: 0;
    pointer-events: none;
  }

  /* shared shimmer style */
  .sk-card,
  .sk-line,
  .sk-subtitle,
  .sk-btn {
    background: linear-gradient(
      90deg,
      rgba(255,255,255,0.12) 0%,
      rgba(255,255,255,0.28) 40%,
      rgba(255,255,255,0.12) 80%
    );
    background-size: 600px 100%;
    animation-name: shimmer;
    animation-duration: 1.4s;
    animation-timing-function: linear;
    animation-iteration-count: infinite;
    border-radius: 16px;
  }

  .sk-card {
    position: absolute;
    width: clamp(200px, 24vw, 310px);
    aspect-ratio: 3/4;
    border-radius: 28px;
    top: 50%;
    transform: translateY(-50%);
  }
  .sk-card-left  { left: 3%;  transform: translateY(-50%) rotate(-6deg); }
  .sk-card-right { right: 3%; transform: translateY(-50%) rotate(5deg); }

  .sk-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    z-index: 1;
  }

  .sk-line {
    height: clamp(3.6rem, 11.2vw, 8.8rem);
    border-radius: 12px;
  }
  .sk-line-1 { width: clamp(200px, 36vw, 520px); animation-delay: 0s; }
  .sk-line-2 { width: clamp(240px, 42vw, 620px); animation-delay: 0.15s; }
  .sk-subtitle { width: clamp(160px, 22vw, 320px); height: 1.2rem; animation-delay: 0.3s; }
  .sk-btn { width: 180px; height: 3rem; border-radius: 100px; animation-delay: 0.45s; }

  @media (max-width: 600px) {
    .sk-card { display: none; }
  }
</style>

<script>
  // ── Ghost skeleton: fade out after page load ──
  const skeleton = document.getElementById("heroSkeleton");
  if (skeleton) {
    const hide = () => {
      skeleton.classList.add("sk-hidden");
      skeleton.addEventListener("transitionend", () => skeleton.remove(), { once: true });
    };
    if (document.readyState === "complete") {
      hide();
    } else {
      window.addEventListener("load", hide);
    }
  }

</script>
