---
const cards = [
  {
    title: "DM VIP",
    titleFont: "italic",
    text: "$15 por mensaje directo",
    gradient: "linear-gradient(135deg, #00e5ff, #00bcd4, #4dd0e1)",
    rotation: "-6deg",
    delay: "0",
    floatDur: "5s",
  },
  {
    title: "VIDEOLLAMADA",
    titleFont: "normal",
    text: "$75 por 15 min de llamada",
    gradient: "linear-gradient(135deg, #7c4dff, #651fff, #b388ff)",
    rotation: "4deg",
    delay: "0.12",
    floatDur: "4.5s",
  },
  {
    title: "cashout",
    titleFont: "normal",
    text: "$500 cobrados este mes",
    gradient: "linear-gradient(135deg, #e040fb, #ea80fc, #f8bbd0)",
    rotation: "6deg",
    delay: "0.24",
    floatDur: "5.5s",
  },
  {
    title: "PREGUNTA VIP",
    titleFont: "italic",
    text: "pago $10 por tu consejo",
    gradient: "linear-gradient(135deg, #536dfe, #7c4dff, #b388ff)",
    rotation: "-4deg",
    delay: "0.18",
    floatDur: "4.8s",
  },
  {
    title: "MI PRECIO",
    titleFont: "normal",
    text: "yo decido cuanto cobro",
    gradient: "linear-gradient(135deg, #ff1744, #ff5252, #ff8a80)",
    rotation: "5deg",
    delay: "0.3",
    floatDur: "5.2s",
  },
];

const avatars = [
  "https://images.unsplash.com/photo-1506794778202-cad84cf45f1d?w=200&h=200&fit=crop&crop=face",
  "https://images.unsplash.com/photo-1534528741775-53994a69daeb?w=200&h=200&fit=crop&crop=face",
];
---

<section class="flood-inbox">
  <!-- Floating cards -->
  {cards.map((card, i) => (
    <div
      class={`fi-card fi-card-${i}`}
      style={`--card-rotation: ${card.rotation}; --card-gradient: ${card.gradient}; --float-dur: ${card.floatDur};`}
      data-reveal="pop"
      data-delay={card.delay}
    >
      <div class="fi-card-top">
        <span class={`fi-card-title ${card.titleFont === "italic" ? "fi-italic" : ""}`}>
          {card.title}
        </span>
      </div>
      <div class="fi-card-bottom">
        <p class="fi-card-text">{card.text}</p>
      </div>
    </div>
  ))}

  <!-- Center avatars -->
  <div class="fi-avatars" data-reveal="scale" data-delay="0.2">
    {avatars.map((src, i) => (
      <div class={`fi-avatar fi-avatar-${i}`}>
        <img src={src} alt="" />
      </div>
    ))}
  </div>

  <!-- Headline -->
  <div class="fi-headline" data-reveal="up" data-delay="0.35">
    <h2 class="fi-title">llena tu<br />inbox</h2>
  </div>
</section>

<style>
  .flood-inbox {
    position: relative;
    z-index: 3;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-end;
    padding: 6rem 2rem 5rem;
    overflow: hidden;
    background: linear-gradient(175deg, #e94693 0%, #e8546b 30%, #eb7545 60%, #f09030 100%);
  }

  /* ── Floating Cards ── */
  .fi-card {
    position: absolute;
    width: clamp(160px, 18vw, 220px);
    border-radius: 16px;
    overflow: hidden;
    box-shadow:
      0 16px 48px rgba(0, 0, 0, 0.22),
      0 4px 12px rgba(0, 0, 0, 0.12);
    transform: rotate(var(--card-rotation));
    z-index: 4;
    animation: fi-float var(--float-dur, 5s) ease-in-out infinite;
    transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    cursor: default;
  }

  .fi-card:hover {
    transform: rotate(0deg) scale(1.08) translateY(-8px);
    box-shadow:
      0 24px 64px rgba(0, 0, 0, 0.3),
      0 8px 20px rgba(0, 0, 0, 0.15);
    z-index: 10;
    animation-play-state: paused;
  }

  .fi-card-top {
    background: var(--card-gradient);
    padding: 1.2rem 1rem 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 52px;
  }

  .fi-card-title {
    font-family: var(--font-feature);
    font-weight: 900;
    font-size: clamp(0.8rem, 1.3vw, 1.1rem);
    text-transform: uppercase;
    color: #fff;
    letter-spacing: 0.04em;
    line-height: 1;
    text-shadow: 1px 2px 6px rgba(0, 0, 0, 0.3);
    text-align: center;
  }

  .fi-italic {
    font-style: italic;
  }

  .fi-card-bottom {
    background: #fff;
    padding: 1rem 1rem 1.2rem;
  }

  .fi-card-text {
    font-family: var(--font);
    font-size: clamp(0.75rem, 1.2vw, 0.95rem);
    font-weight: 600;
    color: #1a1a1a;
    text-align: center;
    line-height: 1.3;
  }

  /* Card positions */
  .fi-card-0 { top: 8%;  left: 14%; }
  .fi-card-1 { top: 4%;  left: 40%; }
  .fi-card-2 { top: 10%; right: 10%; left: auto; }
  .fi-card-3 { top: 40%; left: 10%; }
  .fi-card-4 { top: 42%; right: 8%;  left: auto; }

  /* Staggered float */
  .fi-card-0 { animation-delay: 0s; }
  .fi-card-1 { animation-delay: 0.6s; }
  .fi-card-2 { animation-delay: 1.2s; }
  .fi-card-3 { animation-delay: 0.3s; }
  .fi-card-4 { animation-delay: 0.9s; }

  @keyframes fi-float {
    0%, 100% { translate: 0 0; }
    50%      { translate: 0 -18px; }
  }

  /* ── Center Avatars ── */
  .fi-avatars {
    position: absolute;
    top: 38%;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    align-items: center;
    z-index: 5;
  }

  .fi-avatar {
    width: clamp(80px, 10vw, 120px);
    height: clamp(80px, 10vw, 120px);
    border-radius: 50%;
    overflow: hidden;
    border: 4px solid rgba(255, 255, 255, 0.3);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.25);
    animation: fi-float-avatar 4.5s ease-in-out infinite;
  }

  .fi-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .fi-avatar-0 {
    animation-delay: 0.2s;
    z-index: 2;
  }

  .fi-avatar-1 {
    margin-left: -20px;
    animation-delay: 0.8s;
    z-index: 1;
  }

  @keyframes fi-float-avatar {
    0%, 100% { transform: translateY(0); }
    50%      { transform: translateY(-12px); }
  }

  /* ── Headline ── */
  .fi-headline {
    position: relative;
    z-index: 6;
    margin-top: auto;
    text-align: center;
    padding-top: 4rem;
  }

  .fi-title {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(2.5rem, 8vw, 5.5rem);
    line-height: 0.9;
    color: #fff;
    text-transform: lowercase;
    letter-spacing: -0.03em;
    font-style: italic;
    text-shadow: 0 4px 24px rgba(0, 0, 0, 0.12);
  }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .fi-card { width: clamp(140px, 22vw, 190px); }
    .fi-card-0 { top: 6%;  left: 5%; }
    .fi-card-1 { top: 3%;  left: 35%; }
    .fi-card-2 { top: 8%;  right: 3%; }
    .fi-card-3 { top: 36%; left: 3%; }
    .fi-card-4 { top: 38%; right: 3%; }
  }

  @media (max-width: 768px) {
    .flood-inbox {
      min-height: 90vh;
      padding: 4rem 1rem 3rem;
    }

    .fi-card {
      width: clamp(120px, 38vw, 160px);
    }

    .fi-card-0 { top: 4%;  left: 4%; }
    .fi-card-1 { top: 2%;  left: auto; right: 4%; }
    .fi-card-2 { display: none; }
    .fi-card-3 { top: 32%; left: 2%; }
    .fi-card-4 { top: 34%; right: 2%; left: auto; }

    .fi-avatars {
      top: 28%;
    }

    .fi-avatar {
      width: 70px;
      height: 70px;
    }

    .fi-title {
      font-size: clamp(2rem, 10vw, 3.5rem);
    }

    .fi-headline {
      padding-top: 2rem;
    }
  }
</style>
